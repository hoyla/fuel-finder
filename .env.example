# Fuel Finder API credentials
FUEL_API_ID=your-client-id
FUEL_API_SECRET=your-client-secret

# PostgreSQL connection
DATABASE_URL=postgresql://fuelfinder:fuelfinder@localhost:5432/fuelfinder

# S3 (optional for local dev — raw JSON backups)
S3_BUCKET=fuel-finder-raw
AWS_REGION=eu-west-1

# Set to "true" to skip S3 upload during local dev
SKIP_S3=true
